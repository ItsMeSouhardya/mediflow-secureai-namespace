# Flask
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-separate-long-random-secret
CORS_ORIGINS=http://localhost:5173

# PostgreSQL is the intended operational database.
DATABASE_URL=postgresql+psycopg://mediflow:replace-me@localhost:5432/mediflow
TEST_DATABASE_URL=postgresql+psycopg://mediflow_test:replace-me@localhost:5432/mediflow_test
POSTGRES_DB=mediflow
POSTGRES_USER=mediflow
POSTGRES_PASSWORD=replace-me

# Transitional local verification only. Do not enable in production.
MEDIFLOW_ALLOW_SQLITE=false

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Runtime
LOG_LEVEL=INFO
RATELIMIT_STORAGE_URI=memory://
REDIS_URL=redis://localhost:6379/0
SECURITY_IP_ALLOWLIST=127.0.0.1,::1
SECURITY_EVENT_RETENTION_DAYS=365
API_DEFAULT_RATE_LIMIT=200 per minute
MAX_CONTENT_LENGTH=10485760
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
PASSWORD_RESET_MINUTES=30
ACCOUNT_ACTIVATION_MINUTES=60
REFRESH_COOKIE_NAME=mediflow_refresh
MFA_REQUIRED_FOR_STAFF=false

# Task 5: Encrypted document pipeline
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DOCUMENT_ENCRYPTION_KEY=replace-with-fernet-key
DOCUMENT_ENCRYPTION_KEY_PREV=
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_PATH=backend/document_store
MAX_DOCUMENT_SIZE_BYTES=20971520
ALLOWED_DOCUMENT_EXTENSIONS=pdf,jpg,jpeg,png,tiff,tif,bmp,webp

# S3-compatible storage (set DOCUMENT_STORAGE_BACKEND=s3 and fill these in production)
DOCUMENT_S3_BUCKET=
DOCUMENT_S3_REGION=auto
# Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
DOCUMENT_S3_ENDPOINT_URL=
DOCUMENT_S3_ACCESS_KEY=
DOCUMENT_S3_SECRET_KEY=

# Task 8: Blockchain integrity proof layer (optional/asynchronous)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_DEPLOYER_PRIVATE_KEY=
BLOCKCHAIN_DEVELOPMENT_UNLOCKED_ACCOUNT=false
BLOCKCHAIN_REFERENCE_SECRET=replace-with-a-separate-long-random-secret
BLOCKCHAIN_CONFIRMATIONS=1
BLOCKCHAIN_RETRY_MAX_ATTEMPTS=8
BLOCKCHAIN_RETRY_BASE_SECONDS=30
BLOCKCHAIN_AUDIT_PERIOD_MINUTES=60
BLOCKCHAIN_ABI_PATH=blockchain/artifacts/contracts/MediFlowIntegrity.sol/MediFlowIntegrity.json

# Task 11: Telemedicine
TELEMEDICINE_JITSI_DOMAIN=meet.jit.si
# Leave blank for public meet.jit.si. Set only for your own JWT-enabled Jitsi.
TELEMEDICINE_JITSI_SECRET=
TELEMEDICINE_JITSI_APP_ID=mediflow

# Task 15.14/15.16 — metrics and internal health endpoints
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
METRICS_SECRET_KEY=replace-with-strong-random-secret
APP_VERSION=1.0.0
